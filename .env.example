# PostgreSQL local development
POSTGRES_DB=mcp_experiment
POSTGRES_USER=mcp_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Read-only database role used by the MCP server
MCP_DB_USER=mcp_readonly
MCP_DB_PASSWORD=change-me-readonly

# LLM provider configuration (do not commit real keys)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Audit logs
AUDIT_LOG_PATH=results/raw/audit.jsonl
