flowchart LR
  User["Usuário"] -->|"Pergunta em linguagem natural"| UI["Interface Conversacional"]
  UI --> Agent["Agente LLM"]
  Agent -->|"Chamada de ferramenta"| MCPClient["Cliente MCP"]

  MCPClient -->|"Requisição MCP"| Catalog

  subgraph MCPServer["Servidor MCP de Banco de Dados"]
    direction LR

    subgraph Discovery["Descoberta e Acesso"]
      direction TB
      Catalog["Catálogo de Ferramentas"]
      Auth["Autenticação e Autorização"]
      Catalog -->|"Ferramentas permitidas"| Auth
    end

    subgraph Validation["Validação e Políticas"]
      direction TB
      Validator["Validador de SQL"]
      Policy["Motor de Políticas"]
      Validator -->|"Consulta candidata"| Policy
    end

    subgraph Execution["Execução e Auditoria"]
      direction TB
      Sanitizer["Sanitização de Entrada e Saída"]
      Adapter["Adaptador SQL"]
      Audit["Auditoria e Logs"]
      Sanitizer --> Adapter
      Adapter -->|"Registra execução"| Audit
    end

    Auth --> Validator
    Policy -->|"Aprova ou bloqueia"| Sanitizer
    Policy --> Audit
  end

  Adapter -->|"SQL validado"| DB[("Banco de Dados Relacional")]
  DB -->|"Resultado da consulta"| Adapter
  Audit -->|"Resposta auditada"| MCPClient
  MCPClient --> Agent
  Agent -->|"Resposta final"| UI
  UI --> User

  classDef user fill:#e3f2fd,stroke:#1565c0,stroke-width:1px,color:#0d47a1
  classDef mcp fill:#fff8e1,stroke:#f9a825,stroke-width:1px,color:#5d4037
  classDef db fill:#e8f5e9,stroke:#2e7d32,stroke-width:1px,color:#1b5e20

  class User,UI,Agent,MCPClient user
  class Catalog,Auth,Validator,Policy,Sanitizer,Audit,Adapter mcp
  class DB db
